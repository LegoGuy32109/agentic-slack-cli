{
  "name": "slack-cli",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "bun build --compile --outfile=slack-cli index.ts",
    "build:linux": "bun build --compile --target=bun-linux-x64 --outfile=slack-cli-linux index.ts",
    "build:mac": "bun build --compile --target=bun-darwin-arm64 --outfile=slack-cli-mac index.ts",
    "build:win": "bun build --compile --target=bun-windows-x64 --outfile=slack-cli.exe index.ts"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
